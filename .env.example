# Enterprise DevEx Orchestrator — Environment Configuration
# ─────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   copy .env.example .env     (Windows)
#   cp .env.example .env       (macOS/Linux)
#
# IMPORTANT: Never commit .env to source control.
#
# NOTE: The orchestrator works WITHOUT any of these values.
# When no LLM credentials are provided, it runs in "template-only"
# mode using rule-based parsing, which produces the same output quality.
# Azure credentials are only needed for the `devex deploy` command.

# ── Azure Configuration (required only for deployment) ───────────────
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=rg-devex-orchestrator
AZURE_LOCATION=eastus2

# ── GitHub Copilot SDK (optional — enhances intent parsing) ──────────
# Obtain from https://github.com/settings/copilot
GITHUB_TOKEN=

# ── Azure OpenAI (optional — alternative to Copilot SDK) ────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
